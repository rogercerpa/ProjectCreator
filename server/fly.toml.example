# Fly.io Configuration File
# This will be auto-generated when you run 'flyctl launch'
# This is just an example of what it will look like

app = "your-app-name"
primary_region = "iad"

[build]
  [build.env]
    NODE_ENV = "production"

[env]
  PORT = "8080"
  NODE_ENV = "production"
  WS_HOST = "0.0.0.0"
  LOG_LEVEL = "info"
  MAX_CLIENTS = "100"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  min_machines_running = 1

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 256

