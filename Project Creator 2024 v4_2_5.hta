		<option value="Sikorsky">Sikorsky</option>
	</select>
	</p>
	<p>
	Save Location: <select size="1" name="SaveLocation" >
		<option value="Triage">Triage Folder</option>
		<option value="Desktop">Desktop</option>
		<option value="Server">Server</option>
		    
	</select>
	</p>
	
	</span>
	<p>
	<INPUT TYPE="Button" class="btn" NAME="CreateFolder & Triage" VALUE="Create Folder & Triage" onClick="vbscript:RunBatch2()"/>
	<input type="Button" class="btn" NAME="Download Region Template" VALUE="Download Region Template" style="position: absolute; right: 0;" onClick="vbscript:DownloadRegionTemplate()"/>
	<input type="Button" class="btn" NAME="Upload Triages" VALUE="Upload Triages" style="position: absolute; right: 60;" onClick="vbscript:UploadTriages()"/>
	</P>
	<p>
	<input type="Button" class="btn" NAME="Open Project Folder" VALUE="Open Project Folder" style="position: absolute; right: 0;" onClick="vbscript:OpenProjectFolder()"/>
	</p>
	<span id="RFASettings">


	
	</span>
	
  
</div>

	<div id="Triage" class="tabcontent">
	  <h1>Triage</h1>
	  <table id="Panels" style="position: absolute; right: 75px;">
		<tr><td> LMP's:</td></tr>
		<tr><td>Large</td><td><input type="number" name="LargeLMPs" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>Medium</td><td><input type="number" name="MediumLMPs" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>Small</td><td><input type="number" name="SmallLMPs" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td> nLight:</td></tr>
		<tr><td>ARP 8</td><td><input type="number" name="ARP8" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>ARP 16</td><td><input type="number" name="ARP16" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>ARP 32</td><td><input type="number" name="ARP32" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>ARP 48</td><td><input type="number" name="ARP48" size="5" onchange="vbscript:TriageCalc()"></td></tr>
		<tr><td>Panel Schedules: </td><td><input checked type="radio" name="esheetsSchedules"  onchange="vbscript:TriageCalc()" value="2">No <input type="radio" name="esheetsSchedules" onchange="vbscript:TriageCalc()" value="1">Yes</td></tr>
		<tr><td> (Shown on E-Sheets)</td></tr>
		</table>
	  		
	  <table style="position: relative;">
		<tr><td colspan="2" >Layouts:</td><td>Override:</td></tr>
		<tr><td># of Rooms:</td><td><input type="number" name="numOfRooms" size="5" onchange="vbscript:TriageCalc()">(qty of rooms)</td><td><input type="number" name="OverideRooms" size="5" onchange="vbscript:TriageCalc()">(hr)</td></tr>
		<tr><td>Room Multiplier:</td><td><input type="number" name="roomMultiplier" value="2" size="5" onchange="vbscript:TriageCalc()">(min/room)</td></tr>
		<tr><td>Review/ Setup Time:</td><td><input type="number" name="reviewSetup" value="0.5" min="0" size="5" onchange="vbscript:TriageCalc()">(hr)</td><td><input type="number" name="numofpages" value="1" min="0" size="5" onchange="vbscript:TriageCalc()">(# of lighting pages)</td></tr>
		<tr><td>Spec Review:</td><td><input type="number" name="specReview" value="0.0" min="0" size="5" onchange="vbscript:TriageCalc()">(hr)</td></tr>
	  </table>
	  
	  <table id="subtriage">
		<tr><td colspan="2" >Submittals:</td><td>Override:</td></tr>
		<tr><td># of Rooms:</td><td><input type="number" name="numOfSubRooms" size="5" onchange="vbscript:TriageCalc()">(qty. of rooms)</td><td><input type="number" name="OverideSubRooms" size="5" onchange="vbscript:TriageCalc()">(hr)</td></tr>
		<tr><td>Riser Multiplier:</td><td><input type="number" name="riserMultiplier" value="1" size="5" onchange="vbscript:TriageCalc()"> (min/room)</td></tr>
		<tr><td>SOO:</td><td><input type="number" name="SOO" value="0.5" min="0" size="5" onchange="vbscript:TriageCalc()">(hr)</td></tr>
	  </table>
	  <table id="Photometrics">
		<tr><td colspan="4">
		<select size="4" name="PhotoSW" >
		<option value="VL">Visual Lighting (VL)</option>
		<option value="AGI">AGI</option>
		<option value="M3">M3 AI</option>
		<option value="M3+VL">M3 AI + VL</option>
		</td></tr>
		</table>
	<br>
	Panel Schedules: 
			<input checked type="radio" name="PanelSchedules" onchange="hideshowPanels()" value="2">No
			<input type="radio" name="PanelSchedules" onchange="hideshowPanels()" value="1">Yes
	<br>
	
		<table name="Totaltriage">
		<tr><td>Self Qc:</td><td><input type="number" name="SelfQC" size="5">(hr)</td></tr>
		<tr><td>Fluff:</td><td><input type="number" name="Fluff" size="5">(hr)</td></tr>
		<tr><td>Total Triage Time:</td><td><input type="number" name="TriagedTime" step="0.01" min="1" size="5"> (hr)</input></td></tr>
		</table>
	<br>
			<input checked type="radio" name="FirstAvail" value="2">No
			<input type="radio" name="FirstAvail"  value="1">Yes
			 : Assign to first available (Do this last)
			 <br>
			
			 <br>
		<input type="Button" class="btn" NAME="Copy to DAS Board" VALUE="Copy to DAS Board" onClick="vbscript:DASBoardExport()"/>
		<input type="Button" class="btn" NAME="Copy to Agile" VALUE="Copy to Agile" onClick="vbscript:AgileTriageExport()"/>

	 

		<input type="Button" class="btn" NAME="Open DAS Board" VALUE="Open DAS Board" style="position: absolute; right: 0;" onClick="vbscript:OpenDASBoard()"/>
		<br>
	<select size="1" name="RegionalTeam" style="position: absolute; right: 0;">
		<option value="All">All</option>
		<option value="C&I">C&I</option>
		<option value="NAVS">NAVS</option>

		
		
		<option value="Desktop Emergency Use only">Desktop Emergency Use only</option>
    
			    
	</select>	
	</div>


</body>
</html>
			